\@writefile{lof}{\contentsline {figure}{\numberline {8.3}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Rzeczywisty koszt środowiska w~czerwcu 2026 w~podziale na~usługi (AWS Cost Explorer). Dominuje płaszczyzna sterowania EKS (67,90~USD) --- składnik nieobjęty bezpłatnym limitem; pozostałe usługi (EC2, ELB, RDS) generują koszty rzędu pojedynczych dolarów dzięki Free Tier.}}{65}{figure.caption.41}\protected@file@percent }
\newlabel{fig:june-billing}{{8.3}{65}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Rzeczywisty koszt środowiska w~czerwcu 2026 w~podziale na~usługi (AWS Cost Explorer). Dominuje płaszczyzna sterowania EKS (67,90~USD) --- składnik nieobjęty bezpłatnym limitem; pozostałe usługi (EC2, ELB, RDS) generują koszty rzędu pojedynczych dolarów dzięki Free Tier}{figure.caption.41}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8.4}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Podsumowanie kosztów bieżącego miesiąca (AWS Cost Explorer): koszt narosły do~dnia odczytu (93,71~USD) oraz~prognoza na~cały miesiąc (126,20~USD).}}{66}{figure.caption.42}\protected@file@percent }
\newlabel{fig:forecast-cost}{{8.4}{66}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Podsumowanie kosztów bieżącego miesiąca (AWS Cost Explorer): koszt narosły do~dnia odczytu (93,71~USD) oraz~prognoza na~cały miesiąc (126,20~USD)}{figure.caption.42}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {8.4.1}Profilowanie procesora}{66}{subsection.8.4.1}\protected@file@percent }
\newlabel{subsec:profilowanie}{{8.4.1}{66}{Profilowanie procesora}{subsection.8.4.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8.5}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Flamegraph profilu procesora serwisu zamówień (\lstinline [basicstyle=\ttfamily , numbers=none, frame=none, columns=fullflexible, breaklines=true, breakatwhitespace=false, literate={_}{\_}{1} ]{pprof}), zarejestrowany w~szczycie obciążenia profilu \emph  {max}. Szerokość słupka odpowiada udziałowi funkcji w~czasie procesora. Widoczne są: obsługa żądań HTTP, weryfikacja tokenu JWT (\lstinline [basicstyle=\ttfamily , numbers=none, frame=none, columns=fullflexible, breaklines=true, breakatwhitespace=false, literate={_}{\_}{1} ]{CognitoVerifier.Verify}), zapytania do~PostgreSQL przez~\lstinline [basicstyle=\ttfamily , numbers=none, frame=none, columns=fullflexible, breaklines=true, breakatwhitespace=false, literate={_}{\_}{1} ]{pgx} oraz~(de)serializacja JSON. Znaczną część stanowią wywołania systemowe związane z~siecią i~bazą danych, co~potwierdza ograniczenie operacjami wejścia--wyjścia, nie~mocą obliczeniową.}}{66}{figure.caption.43}\protected@file@percent }
\newlabel{fig:order-service-flamegraph}{{8.5}{66}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Flamegraph profilu procesora serwisu zamówień (\code {pprof}), zarejestrowany w~szczycie obciążenia profilu \emph {max}. Szerokość słupka odpowiada udziałowi funkcji w~czasie procesora. Widoczne są: obsługa żądań HTTP, weryfikacja tokenu JWT (\code {CognitoVerifier.Verify}), zapytania do~PostgreSQL przez~\code {pgx} oraz~(de)serializacja JSON. Znaczną część stanowią wywołania systemowe związane z~siecią i~bazą danych, co~potwierdza ograniczenie operacjami wejścia--wyjścia, nie~mocą obliczeniową}{figure.caption.43}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8.6}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Flamegraph profilu procesora serwisu produktów (\lstinline [basicstyle=\ttfamily , numbers=none, frame=none, columns=fullflexible, breaklines=true, breakatwhitespace=false, literate={_}{\_}{1} ]{pprof}) w~szczycie obciążenia profilu \emph  {max}. Podobnie jak w~serwisie zamówień dominują wywołania systemowe (operacje sieciowe i~bazodanowe), a~spośród operacji obliczeniowych wyróżniają się weryfikacja JWT oraz~kodowanie JSON --- profil potwierdza, że~usługa jest~ograniczona wejściem--wyjściem.}}{67}{figure.caption.44}\protected@file@percent }
\newlabel{fig:product-service-flamegraph}{{8.6}{67}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Flamegraph profilu procesora serwisu produktów (\code {pprof}) w~szczycie obciążenia profilu \emph {max}. Podobnie jak w~serwisie zamówień dominują wywołania systemowe (operacje sieciowe i~bazodanowe), a~spośród operacji obliczeniowych wyróżniają się weryfikacja JWT oraz~kodowanie JSON --- profil potwierdza, że~usługa jest~ograniczona wejściem--wyjściem}{figure.caption.44}{}}
