\contentsline {figure}{\numberline {7.4}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Widok szczegółów zamówienia zrealizowanego serwisu.}}{51}{figure.caption.14}%
\contentsline {figure}{\numberline {7.5}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Widok płatności zrealizowanego serwisu.}}{52}{figure.caption.15}%
\contentsline {figure}{\numberline {7.6}{\ignorespaces \xpg@aux {}{polish}\ignorespaces Widok historii zamówień zrealizowanego serwisu.}}{52}{figure.caption.16}%
